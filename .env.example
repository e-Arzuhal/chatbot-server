# Ortam: development | production
APP_ENV=development

# Production'da loopback kullan: HOST=127.0.0.1
HOST=0.0.0.0
PORT=8003
DEBUG=true

# Opsiyonel: LLM entegrasyonu (yoksa kural tabanli sistem kullanilir)
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash

# Güvenlik (Production'da mutlaka set et)
# Chatbot hem main-server hem frontend'den erişilebilir
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
# Dahili servis API anahtarı — main-server ile aynı değer olmalı
# APP_ENV=production iken zorunludur
INTERNAL_API_KEY=
